# Empty means same-origin API calls through Cloudflare Pages Functions.
VITE_API_BASE=

# Keep empty for Cloudflare Pages unless you intentionally use another API gateway.
# VITE_API_BASE=https://your-domain.example

# Server-side Cloudflare Pages Function settings for Hotmail/Outlook lookup.
# In production, set HOTMAIL_API_KEY as a Pages secret; do not expose it to browser code.
HOTMAIL_API_BASE=https://mail.dgx.cc.cd
HOTMAIL_API_KEY=
